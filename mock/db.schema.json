{
  "type": "object",
  "_comment": "Còn thiếu bảng  rentals, rental_items, borrowings, borrowing_items, maintenances, maintenance_items, returns, return_items, invoices, invoice_items,  để quản lý quá trình thuê, trả, bảo trì trang phục và đạo cụ",
  "required": [
    "users",
    "revoke_tokens",
    "employees",
    "warehouses",
    "categories",
    "costumes",
    "images",
    "equipment_props",
    "inventory_item_conditions",
    "inventory"
  ],
  "definitions": {
    "BaseEntity": {
      "type": "object",
      "additionalProperties": true,
      "_comment": "BaseEntity định nghĩa các trường chung cho tất cả các thực thể, giúp giảm thiểu sự lặp lại trong schema",
      "properties": {
        "id": {
          "type": "integer"
        },
        "is_active": {
          "type": "boolean",
          "default": true
        },
        "created_by": {
          "type": "integer"
        },
        "updated_by": {
          "type": "integer"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "default": "2026-04-19T00:00:00.000Z"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "remark": {
          "type": "string"
        }
      },
      "required": ["id", "is_active", "created_at"]
    },
    "ImageMetadata": {
      "_comment": "ImageMetadata định nghĩa các trường metadata cơ bản cho hình ảnh, giúp chuẩn hóa cách lưu trữ thông tin về hình ảnh trong hệ thống",
      "type": "object",
      "properties": {
        "file_name": { "type": "string" },
        "size": { "type": "integer" },
        "dest": { "type": "string", "format": "url" },
        "mime_type": { "type": "string", "enum": ["image/png", "image/jpg", "image/jpeg", "image/webp"] }
      },
      "required": ["file_name", "size", "dest", "mime_type"]
    },
    "User": {
      "_comment": "User định nghĩa các trường thông tin cơ bản cho người dùng, bao gồm thông tin đăng nhập và vai trò, giúp quản lý quyền truy cập trong hệ thống",
      "allOf": [
        { "$ref": "#/definitions/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "employee_id": { "type": ["integer", "null"] },
            "role": { "type": "string", "enum": ["ADMIN", "USER"] }
          },
          "required": ["username", "password", "role"]
        }
      ]
    },
    "RevokeToken": {
      "type": "object",
      "properties": {
        "access_token": {
          "type": "string"
        }
      }
    },
    "Employee": {
      "allOf": [
        {
          "$ref": "#/definitions/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "employee_code": {
              "type": "string"
            },
            "user_id": {
              "type": ["integer", "null"]
            },
            "full_name": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "phone": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "citizen_id_number": {
              "type": "string",
              "format": "number"
            },
            "position": {
              "type": "string",
              "enum": ["MANAGER", "WAREHOUSE_MANAGER", "ORDER_PROCESSOR", "TALENT", "TECHICAL_CREW", "WARDROBE"]
            },
            "work_status": {
              "type": "string",
              "enum": ["ACTIVE", "SUSPENDED", "EXITED"]
            }
          },
          "required": [
            "employee_code",
            "user_id",
            "full_name",
            "email",
            "phone",
            "address",
            "citizen_id_number",
            "position",
            "work_status"
          ]
        }
      ]
    },
    "Warehouse": {
      "allOf": [
        {
          "$ref": "#/definitions/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": ["COSTUME", "EQUIPMENT_PROPS"]
            },
            "managed_by": {
              "type": "number"
            }
          }
        }
      ]
    },
    "ImageGallery": {
      "allOf": [
        { "$ref": "#/definitions/BaseEntity" },
        { "$ref": "#/definitions/ImageMetadata" },
        {
          "type": "object",
          "properties": {
            "category_id": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "ItemCategory": {
      "allOf": [
        { "$ref": "#/definitions/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string" },
            "type": { "type": "string", "enum": ["COSTUME", "EQUIPMENT_PROPS"] }
          }
        }
      ]
    },
    "Costume": {
      "allOf": [
        { "$ref": "#/definitions/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "sku": {
              "type": "string",
              "_comment": "Mã định danh duy nhất cho mỗi trang phục, giúp quản lý và tra cứu dễ dàng trong hệ thống"
            },
            "slug": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "category_id": {
              "type": "integer"
            },
            "color": {
              "type": "object",
              "properties": {
                "hex": { "type": "string" },
                "code": { "type": "string" },
                "intensity": { "type": "integer" }
              }
            },
            "sizes": {
              "type": "array",
              "items": { "type": "string", "enum": ["XS", "S", "M", "L", "XL", "2XL", "3XL"] }
            },
            "unit": {
              "type": "string",
              "enum": ["SET", "PIECE"]
            },
            "gender": {
              "type": "string",
              "enum": ["MALE", "FEMALE", "UNISEX"]
            },
            "images": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "rental_price_per_day": {
              "type": "integer",
              "minimum": 50000
            },
            "description": {
              "type": "string"
            },
            "hashtags": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        { "required": ["slug", "name", "category_id", "color", "sizes", "unit", "gender", "rental_price_per_day"] }
      ]
    },
    "EquipmentProps": {
      "allOf": [
        {
          "$ref": "#/definitions/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string" },
            "category_id": { "type": "integer" },
            "unit": { "type": "string" },
            "description": { "type": "string" },
            "images": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "hashtags": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
          }
        }
      ]
    },
    "InventoryCondition": {
      "allOf": [
        { "$ref": "#/definitions/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "code": { "type": "string", "enum": ["A", "B", "C"] },
            "label": {
              "type": "string",
              "_comment": "Mô tả chi tiết về tình trạng của sản phẩm, giúp nhân viên kho hiểu rõ hơn về tình trạng thực tế của sản phẩm"
            },
            "discount_rate": { "type": "number", "maxium": 0.5, "minimum": 0 },
            "rentable": {
              "type": "boolean",
              "default": true,
              "_comment": "Nếu code = 'C' thì rentable luôn là false, không cho phép thuê sản phẩm trong tình trạng này"
            },
            "badge_color": { "type": "string", "_comment": "Sử dụng mã hex để đánh dấu" }
          }
        }
      ]
    },
    "Inventory": {
      "allOf": [
        {
          "$ref": "#/definitions/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "sku": {
              "type": "string",
              "_comment": "Mã định danh duy nhất cho mỗi sản phẩm tồn kho, giúp quản lý và tra cứu dễ dàng trong hệ thống"
            },
            "item_id": { "type": "integer", "_comment": "Khóa ngoại tham chiếu tới bảng 'warehouses'" },
            "item_type": { "type": "string", "enum": ["COSTUME", "EQUIPMENT_PROPS"] },
            "inventory_condition_id": {
              "type": "integer",
              "$comment": "Khóa ngoại tham chiếu tới bảng 'inventory_conditions'"
            },
            "warehouse_id": { "type": "integer", "_comment": "Khóa ngoại tham chiếu tới bảng 'warehouses'" },
            "status": {
              "type": "string",
              "enum": ["AVAILABLE", "RENTED", "MAINTENANCE", "DISPOSED"],
              "_comment": "Trạng thái của sản phẩm trong kho, giúp quản lý quá trình thuê và bảo trì"
            },
            "size": {
              "type": ["string", "null"],
              "enum": ["XS", "S", "M", "L", "XL", "2XL", "3XL"],
              "_comment": "Kích thước của sản phẩm, áp dụng cho trang phục, có thể null đối với đạo cụ"
            }
          }
        }
      ]
    }
  },
  "properties": {
    "users": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/User"
      },
      "description": "Danh sách người dùng"
    },
    "employees": {
      "type": "array",
      "uniqueItems": true,
      "description": "Danh sách nhân viên",
      "items": {
        "$ref": "#/definitions/Employee"
      }
    },
    "revoke_tokens": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RevokeToken"
      }
    },
    "warehouses": {
      "type": "array",
      "description": "Danh sách kho",
      "items": {
        "$ref": "#/definitions/Warehouse"
      }
    },
    "images": {
      "type": "array",
      "uniqueItems": true,
      "description": "Danh sách ảnh gồm thông tin metadata ảnh",
      "items": {
        "$ref": "#/definitions/ImageGallery"
      }
    },
    "categories": {
      "type": "array",
      "uniqueItems": true,
      "description": "Danh sách danh mục",
      "items": {
        "$ref": "#/definitions/ItemCategory"
      }
    },
    "costumes": {
      "type": "array",
      "description": "Danh sách trang phục",
      "items": {
        "$ref": "#/definitions/Costume"
      }
    },
    "equipment_props": {
      "type": "array",
      "description": "Danh sách các đạo cụ",
      "items": {
        "$ref": "#/definitions/EquipmentProps"
      }
    },
    "inventory_conditions": {
      "type": "array",
      "description": "Danh sách các tình trạng của sản phẩm trong kho",
      "items": {
        "$ref": "#/definitions/InventoryCondition"
      }
    },
    "inventory": {
      "type": "array",
      "description": "Danh sách tồn kho, quản lý số lượng và tình trạng của từng sản phẩm trong kho",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/Inventory"
      }
    }
  }
}
