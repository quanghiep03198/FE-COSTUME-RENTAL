{
  "type": "object",
  "required": [
    "users",
    "revoke_tokens",
    "employees",
    "warehouses",
    "categories",
    "costumes",
    "equipment_props",
    "inventory"
  ],
  "$defs": {
    "BaseEntity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "integer"
        },
        "is_active": {
          "type": "boolean",
          "default": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "default": "2026-04-19T00:00:00.000Z"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "remark": {
          "type": "string"
        }
      },
      "required": ["id", "is_active", "created_at"]
    },
    "ImageMetadata": {
      "type": "object",
      "properties": {
        "file_name": { "type": "string" },
        "size": { "type": "integer" },
        "dest": { "type": "string", "format": "url" },
        "mime_type": { "type": "string", "enum": ["image/png", "image/jpg", "image/jpeg", "image/webp"] }
      },
      "required": ["file_name", "size", "dest", "mime_type"]
    },
    "User": {
      "allOf": [
        { "$ref": "#/$defs/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "employee_id": { "type": ["integer", "null"] },
            "role": { "type": "string", "enum": ["ADMIN", "USER"] }
          },
          "required": ["username", "password", "role"]
        }
      ]
    },
    "RevokeToken": {
      "type": "object",
      "properties": {
        "access_token": {
          "type": "string"
        }
      }
    },
    "Employee": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "employee_code": {
              "type": "string"
            },
            "user_id": {
              "type": ["integer", "null"]
            },
            "full_name": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "phone": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "citizen_id_number": {
              "type": "string",
              "format": "number"
            },
            "position": {
              "type": "string",
              "enum": ["MANAGER", "WAREHOUSE_MANAGER", "ORDER_PROCESSOR", "TALENT", "TECHICAL_CREW", "WARDROBE"]
            },
            "work_status": {
              "type": "string",
              "enum": ["ACTIVE", "SUSPENDED", "EXITED"]
            }
          },
          "required": [
            "employee_code",
            "user_id",
            "full_name",
            "email",
            "phone",
            "address",
            "citizen_id_number",
            "position",
            "work_status"
          ]
        }
      ]
    },
    "Warehouse": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "warehouse_code": {
              "type": "string"
            },
            "warehouse_type": {
              "type": "string",
              "enum": ["COSTUME_WAREHOUSE", "EQUIPMENT_PROPS_WAREHOUSE"]
            },
            "manager_employee_id": {
              "type": "number"
            }
          }
        }
      ]
    },
    "ImageGallery": {
      "allOf": [
        { "$ref": "#/$defs/BaseEntity" },
        { "$ref": "#/$defs/ImageMetadata" },
        {
          "type": "object",
          "properties": {
            "category_id": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "ItemCategory": {
      "allOf": [
        { "$ref": "#/$defs/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string" },
            "type": { "type": "string", "enum": ["COSTUME", "EQUIPMENT_PROPS"] }
          }
        }
      ]
    },
    "Costume": {
      "allOf": [
        { "$ref": "#/$defs/BaseEntity" },
        {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "category_id": {
              "type": "integer"
            },
            "color": {
              "type": "string"
            },
            "sizes": {
              "type": "array",
              "items": { "type": "string", "enum": ["XS", "S", "M", "L", "XL", "XXL", "XXXL"] }
            },
            "unit": {
              "type": "string",
              "enum": ["SET", "PIECE"]
            },
            "gender": {
              "type": "string",
              "enum": ["MALE", "FEMALE", "UNISEX"]
            },
            "images": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "rental_price_per_day": {
              "type": "integer",
              "minimum": 50000
            },
            "description": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        },
        { "required": ["slug", "name", "category_id", "color", "sizes", "unit", "gender", "rental_price_per_day"] }
      ]
    },
    "EquipmentProps": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseEntity"
        },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string" },
            "category_id": { "type": "integer" },
            "rental_price_per_day": { "type": "integer" },
            "weight_kg": { "type": "number" },
            "dimensions": {
              "type": ["object", "null"],
              "properties": {
                "width_cm": { "type": "number" },
                "height_cm": { "type": "number" },
                "depth_cm": { "type": "number" }
              }
            },
            "is_fragile": { "type": "boolean" },
            "description": { "type": "string" },
            "image_id": { "type": "integer" },
            "tags": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
          }
        }
      ]
    }
  },
  "properties": {
    "users": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/User"
      },
      "description": "Users collection"
    },
    "employees": {
      "type": "array",
      "uniqueItems": true,
      "description": "Employee collection",
      "items": {
        "$ref": "#/$defs/Employee"
      }
    },
    "revoke_tokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RevokeToken"
      }
    },
    "warehouses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Warehouse"
      }
    },
    "images": {
      "type": "array",
      "uniqueItems": true,
      "description": "Images gallerr, store images's metadata",
      "items": {
        "$ref": "#/$defs/ImageGallery"
      }
    },
    "categories": {
      "type": "array",
      "uniqueItems": true,
      "description": "Costume category collection",
      "items": {
        "$ref": "#/$defs/ItemCategory"
      }
    },
    "costumes": {
      "type": "array",
      "description": "Costume collection",
      "items": {
        "$ref": "#/$defs/Costume"
      }
    },
    "equipment_props": {
      "type": "array",
      "description": "Equipment props collection",
      "items": {
        "$ref": "#/$defs/EquipmentProps"
      }
    }
  }
}
